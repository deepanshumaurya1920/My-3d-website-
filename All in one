<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Hero Section</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --purple: #8b2fc9;
      --purple-light: #bf5af2;
      --cyan: #00e5ff;
      --cyan-dim: #00b8d4;
      --black: #020408;
      --glass-bg: rgba(10, 5, 20, 0.55);
      --glass-border: rgba(0, 229, 255, 0.18);
    }

    body {
      background: var(--black);
      font-family: 'Rajdhani', sans-serif;
      min-height: 100vh;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* ── Animated gradient background ── */
    .bg-gradient {
      position: fixed; inset: 0; z-index: 0;
      background: radial-gradient(ellipse 80% 60% at 20% 40%, rgba(139,47,201,0.35) 0%, transparent 60%),
                  radial-gradient(ellipse 70% 50% at 80% 60%, rgba(0,229,255,0.22) 0%, transparent 60%),
                  radial-gradient(ellipse 60% 80% at 50% 10%, rgba(100,0,180,0.18) 0%, transparent 70%),
                  #020408;
      animation: bgPulse 8s ease-in-out infinite alternate;
    }
    @keyframes bgPulse {
      0%   { filter: hue-rotate(0deg) brightness(1); }
      50%  { filter: hue-rotate(15deg) brightness(1.15); }
      100% { filter: hue-rotate(-10deg) brightness(0.9); }
    }

    /* ── 3D Robot canvas ── */
    canvas {
      position: fixed; inset: 0; z-index: 1;
      opacity: 0.85;
    }

    /* ── Grid overlay ── */
    .grid-overlay {
      position: fixed; inset: 0; z-index: 2;
      background-image:
        linear-gradient(rgba(0,229,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,229,255,0.04) 1px, transparent 1px);
      background-size: 60px 60px;
      animation: gridMove 20s linear infinite;
    }
    @keyframes gridMove {
      from { background-position: 0 0, 0 0; }
      to   { background-position: 60px 60px, 60px 60px; }
    }

    /* ── Scanlines ── */
    .scanlines {
      position: fixed; inset: 0; z-index: 3; pointer-events: none;
      background: repeating-linear-gradient(
        0deg,
        transparent, transparent 2px,
        rgba(0,0,0,0.08) 2px, rgba(0,0,0,0.08) 4px
      );
    }

    /* ── Floating particles ── */
    .particles { position: fixed; inset: 0; z-index: 4; overflow: hidden; pointer-events: none; }
    .particle {
      position: absolute;
      border-radius: 50%;
      animation: float linear infinite;
    }
    @keyframes float {
      0%   { transform: translateY(100vh) rotate(0deg); opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { transform: translateY(-10vh) rotate(720deg); opacity: 0; }
    }

    /* ── Hero container ── */
    .hero {
      position: relative; z-index: 10;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center;
      padding: 60px 40px;
      width: min(860px, 92vw);
      animation: heroReveal 1.2s cubic-bezier(0.16,1,0.3,1) forwards;
      opacity: 0;
    }
    @keyframes heroReveal {
      from { opacity: 0; transform: translateY(40px) scale(0.96); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ── Glass card ── */
    .glass-card {
      position: absolute; inset: 0; border-radius: 24px;
      background: var(--glass-bg);
      backdrop-filter: blur(28px) saturate(160%);
      -webkit-backdrop-filter: blur(28px) saturate(160%);
      border: 1px solid var(--glass-border);
      box-shadow:
        0 0 0 1px rgba(139,47,201,0.15),
        0 8px 60px rgba(0,0,0,0.7),
        inset 0 1px 0 rgba(255,255,255,0.06),
        0 0 80px rgba(0,229,255,0.06);
      overflow: hidden;
    }
    .glass-card::before {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(139,47,201,0.12) 0%, transparent 50%, rgba(0,229,255,0.08) 100%);
      border-radius: inherit;
    }
    .glass-card::after {
      content: '';
      position: absolute; top: 0; left: -60%;
      width: 40%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent);
      animation: shimmer 6s ease-in-out infinite;
    }
    @keyframes shimmer {
      0%, 100% { left: -60%; }
      50%       { left: 120%; }
    }

    /* ── Corner accents ── */
    .corner { position: absolute; width: 24px; height: 24px; }
    .corner.tl { top: 16px; left: 16px; border-top: 2px solid var(--cyan); border-left: 2px solid var(--cyan); }
    .corner.tr { top: 16px; right: 16px; border-top: 2px solid var(--cyan); border-right: 2px solid var(--cyan); }
    .corner.bl { bottom: 16px; left: 16px; border-bottom: 2px solid var(--purple-light); border-left: 2px solid var(--purple-light); }
    .corner.br { bottom: 16px; right: 16px; border-bottom: 2px solid var(--purple-light); border-right: 2px solid var(--purple-light); }

    /* ── Content ── */
    .hero-content { position: relative; z-index: 1; }

    .status-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(0,229,255,0.08);
      border: 1px solid rgba(0,229,255,0.3);
      border-radius: 100px;
      padding: 6px 18px;
      font-size: 11px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--cyan);
      margin-bottom: 32px;
      animation: heroReveal 1.2s 0.2s cubic-bezier(0.16,1,0.3,1) both;
    }
    .status-dot {
      width: 7px; height: 7px;
      background: var(--cyan);
      border-radius: 50%;
      box-shadow: 0 0 8px var(--cyan);
      animation: blink 1.5s ease-in-out infinite;
    }
    @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

    h1 {
      font-family: 'Orbitron', monospace;
      font-size: clamp(2.2rem, 5.5vw, 4.2rem);
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -1px;
      margin-bottom: 24px;
      animation: heroReveal 1.2s 0.35s cubic-bezier(0.16,1,0.3,1) both;
    }
    .gradient-text {
      background: linear-gradient(135deg, #fff 0%, var(--purple-light) 40%, var(--cyan) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 0 30px rgba(0,229,255,0.3));
    }

    .subtitle {
      font-size: clamp(1rem, 2.2vw, 1.25rem);
      color: rgba(255,255,255,0.55);
      letter-spacing: 2px;
      text-transform: uppercase;
      font-weight: 300;
      margin-bottom: 48px;
      animation: heroReveal 1.2s 0.5s cubic-bezier(0.16,1,0.3,1) both;
    }
    .subtitle span { color: var(--cyan-dim); }

    /* ── Buttons ── */
    .btn-group {
      display: flex; gap: 20px; flex-wrap: wrap; justify-content: center;
      animation: heroReveal 1.2s 0.65s cubic-bezier(0.16,1,0.3,1) both;
    }

    .btn {
      position: relative; overflow: hidden;
      padding: 14px 36px;
      font-family: 'Orbitron', monospace;
      font-size: 12px; font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      border-radius: 6px;
      cursor: pointer; border: none;
      transition: transform 0.2s, box-shadow 0.3s;
      text-decoration: none;
    }
    .btn:hover { transform: translateY(-3px); }

    .btn-primary {
      background: linear-gradient(135deg, var(--purple) 0%, var(--purple-light) 100%);
      color: #fff;
      box-shadow: 0 0 30px rgba(139,47,201,0.5), 0 4px 20px rgba(0,0,0,0.4);
    }
    .btn-primary:hover {
      box-shadow: 0 0 50px rgba(191,90,242,0.7), 0 8px 30px rgba(0,0,0,0.5);
    }
    .btn-primary::after {
      content: ''; position: absolute;
      top: -50%; left: -60%; width: 40%; height: 200%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
      transform: skewX(-20deg);
      transition: left 0.5s;
    }
    .btn-primary:hover::after { left: 130%; }

    .btn-secondary {
      background: transparent;
      color: var(--cyan);
      border: 1px solid rgba(0,229,255,0.45);
      box-shadow: 0 0 20px rgba(0,229,255,0.15), inset 0 0 20px rgba(0,229,255,0.04);
    }
    .btn-secondary:hover {
      background: rgba(0,229,255,0.08);
      border-color: var(--cyan);
      box-shadow: 0 0 40px rgba(0,229,255,0.4), inset 0 0 30px rgba(0,229,255,0.08);
    }

    /* ── Bottom data line ── */
    .data-line {
      position: absolute; bottom: 22px; left: 50%; transform: translateX(-50%);
      display: flex; gap: 28px;
      font-size: 9px; letter-spacing: 2px;
      color: rgba(0,229,255,0.35);
      font-family: 'Orbitron', monospace;
      white-space: nowrap;
    }
    .data-line span::before { content: '// '; color: rgba(139,47,201,0.5); }

    /* ── Neon line ── */
    .neon-line {
      width: 120px; height: 1px;
      margin: 0 auto 36px;
      background: linear-gradient(90deg, transparent, var(--cyan), var(--purple-light), transparent);
      animation: heroReveal 1.2s 0.45s cubic-bezier(0.16,1,0.3,1) both;
    }
  </style>
</head>
<body>

  <div class="bg-gradient"></div>
  <canvas id="robotCanvas"></canvas>
  <div class="grid-overlay"></div>
  <div class="scanlines"></div>
  <div class="particles" id="particles"></div>

  <section class="hero">
    <div class="glass-card">
      <div class="corner tl"></div>
      <div class="corner tr"></div>
      <div class="corner bl"></div>
      <div class="corner br"></div>
    </div>
    <div class="hero-content">
      <div class="status-badge"><span class="status-dot"></span>Available for hire</div>
      <h1><span class="gradient-text">I Build Websites<br>That Convert</span></h1>
      <div class="neon-line"></div>
      <p class="subtitle">Freelance Web Developer <span>// crafting digital experiences</span></p>
      <div class="btn-group">
        <a href="#" class="btn btn-primary">See My Work</a>
        <a href="#" class="btn btn-secondary">Contact Me</a>
      </div>
    </div>
    <div class="data-line">
      <span>SYS.ONLINE</span>
      <span>NODE.JS / REACT</span>
      <span>UI/UX READY</span>
    </div>
  </section>

  <script>
    /* ─────────────── 3D ROBOT WIREFRAME ─────────────── */
    const canvas = document.getElementById('robotCanvas');
    const ctx    = canvas.getContext('2d');
    let W, H, cx, cy;
    function resize() {
      W = canvas.width  = window.innerWidth;
      H = canvas.height = window.innerHeight;
      cx = W / 2; cy = H / 2;
    }
    resize();
    window.addEventListener('resize', resize);

    let mouseX = 0, mouseY = 0;
    document.addEventListener('mousemove', e => {
      mouseX = (e.clientX - W/2) / W * 2;
      mouseY = (e.clientY - H/2) / H * 2;
    });

    /* ── Projection ── */
    function project(x, y, z, rx, ry, scale) {
      // rotate Y
      let x1 = x * Math.cos(ry) - z * Math.sin(ry);
      let z1 = x * Math.sin(ry) + z * Math.cos(ry);
      // rotate X
      let y1 = y * Math.cos(rx) - z1 * Math.sin(rx);
      let z2 = y * Math.sin(rx) + z1 * Math.cos(rx);
      const fov = 500;
      const d = fov / (fov + z2 + 400);
      return {
        x: x1 * d * scale + cx,
        y: y1 * d * scale + cy,
        z: z2, d
      };
    }

    /* ── Robot geometry (vertices + edges) ── */
    function makeRobot() {
      const v = [];
      const e = [];
      function addBox(x,y,z, w,h,d, group) {
        const base = v.length;
        const hw=w/2, hh=h/2, hd=d/2;
        const pts = [
          [-hw,-hh,-hd],[hw,-hh,-hd],[hw,hh,-hd],[-hw,hh,-hd],
          [-hw,-hh, hd],[hw,-hh, hd],[hw,hh, hd],[-hw,hh, hd],
        ];
        pts.forEach(p => v.push([p[0]+x, p[1]+y, p[2]+z, group]));
        const ei = [
          [0,1],[1,2],[2,3],[3,0],
          [4,5],[5,6],[6,7],[7,4],
          [0,4],[1,5],[2,6],[3,7]
        ];
        ei.forEach(([a,b]) => e.push([base+a, base+b, group]));
      }
      function addCircle(x,y,z, r, axis, segs, group) {
        const base = v.length;
        for(let i=0;i<segs;i++) {
          const a = (i/segs)*Math.PI*2;
          if(axis==='y') v.push([x+Math.cos(a)*r, y, z+Math.sin(a)*r, group]);
          else if(axis==='x') v.push([x, y+Math.cos(a)*r, z+Math.sin(a)*r, group]);
          else v.push([x+Math.cos(a)*r, y+Math.sin(a)*r, z, group]);
          if(i>0) e.push([base+i-1, base+i, group]);
        }
        e.push([base+segs-1, base, group]);
      }
      // body
      addBox(0,20,0, 80,100,50, 0);
      // head
      addBox(0,-60,0, 60,50,45, 1);
      // neck
      addBox(0,-10,0, 20,20,20, 1);
      // eyes
      addCircle(-12,-60,23, 8,'z',12, 2);
      addCircle( 12,-60,23, 8,'z',12, 2);
      // shoulder L/R
      addBox(-65,0,0, 30,30,30, 3);
      addBox( 65,0,0, 30,30,30, 3);
      // upper arm L/R
      addBox(-80,35,0, 22,55,22, 3);
      addBox( 80,35,0, 22,55,22, 3);
      // lower arm L/R
      addBox(-80,80,0, 18,50,18, 3);
      addBox( 80,80,0, 18,50,18, 3);
      // hand L/R
      addBox(-80,112,0, 22,20,22, 3);
      addBox( 80,112,0, 22,20,22, 3);
      // chest detail rings
      addCircle(0,10,25, 20,'z',20, 4);
      addCircle(0,30,25, 15,'z',16, 4);
      // hip
      addBox(0,75,0, 70,25,45, 0);
      // upper leg L/R
      addBox(-20,110,0, 28,55,28, 5);
      addBox( 20,110,0, 28,55,28, 5);
      // lower leg L/R
      addBox(-20,155,0, 24,55,24, 5);
      addBox( 20,155,0, 24,55,24, 5);
      // feet L/R
      addBox(-20,188,5, 30,18,40, 5);
      addBox( 20,188,5, 30,18,40, 5);
      // head antenna
      addBox(0,-93,0, 4,20,4, 1);
      addCircle(0,-104,0, 6,'z',10, 2);
      return {v, e};
    }

    const robot = makeRobot();
    const groupColors = [
      '#00b8d4','#bf5af2','#00e5ff','#e040fb','#7c4dff','#00e5ff'
    ];
    const groupGlows = [
      'rgba(0,184,212,0.8)','rgba(191,90,242,0.8)',
      'rgba(0,229,255,1)','rgba(224,64,251,0.8)',
      'rgba(124,77,255,0.8)','rgba(0,229,255,0.8)'
    ];

    let t = 0;
    function draw() {
      ctx.clearRect(0, 0, W, H);
      t += 0.012;

      const baseRY = t * 0.4 + mouseX * 0.6;
      const baseRX = Math.sin(t * 0.3) * 0.15 + mouseY * 0.25;
      const scale  = Math.min(W, H) / 520;
      // bob
      const bobY = Math.sin(t) * 8;

      const proj = robot.v.map(([x,y,z]) =>
        project(x, y + bobY, z, baseRX, baseRY, scale)
      );

      // sort edges by avg z (painter)
      const sorted = [...robot.e].sort((a,b) => {
        const za = (proj[a[0]].z + proj[a[1]].z)/2;
        const zb = (proj[b[0]].z + proj[b[1]].z)/2;
        return za - zb;
      });

      sorted.forEach(([ai, bi, g]) => {
        const A = proj[ai], B = proj[bi];
        if (!A || !B) return;
        const avgD = (A.d + B.d) / 2;
        const alpha = Math.min(0.85, 0.3 + avgD * 0.6);
        ctx.beginPath();
        ctx.moveTo(A.x, A.y);
        ctx.lineTo(B.x, B.y);
        ctx.strokeStyle = groupColors[g] || '#00e5ff';
        ctx.lineWidth = Math.max(0.5, avgD * 2.2);
        ctx.globalAlpha = alpha;
        ctx.shadowColor  = groupGlows[g] || '#00e5ff';
        ctx.shadowBlur   = 12 * avgD;
        ctx.stroke();
      });

      // glowing eye pulses
      const eyePulse = (Math.sin(t * 3) + 1) / 2;
      [-12, 12].forEach(ex => {
        const ep = project(ex * scale * 1.3, -60 + bobY, 25, baseRX, baseRY, scale);
        ctx.beginPath();
        ctx.arc(ep.x, ep.y, 5 * scale * ep.d, 0, Math.PI*2);
        ctx.fillStyle = `rgba(0,229,255,${0.6 + eyePulse * 0.4})`;
        ctx.shadowColor = '#00e5ff';
        ctx.shadowBlur = 20 * eyePulse;
        ctx.globalAlpha = 0.9;
        ctx.fill();
      });

      ctx.globalAlpha = 1;
      ctx.shadowBlur  = 0;
      requestAnimationFrame(draw);
    }
    draw();

    /* ─────────────── PARTICLES ─────────────── */
    const container = document.getElementById('particles');
    for (let i = 0; i < 30; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      const size = Math.random() * 3 + 1;
      const isCyan = Math.random() > 0.5;
      p.style.cssText = `
        width:${size}px; height:${size}px;
        left:${Math.random()*100}%;
        background:${isCyan ? 'var(--cyan)' : 'var(--purple-light)'};
        box-shadow:0 0 ${size*3}px ${isCyan ? 'var(--cyan)' : 'var(--purple-light)'};
        animation-duration:${6+Math.random()*12}s;
        animation-delay:${Math.random()*10}s;
      `;
      container.appendChild(p);
    }
  </script>
</body>
</html>
